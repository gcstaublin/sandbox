---
import "../styles/global.css";
---

{/* ================================== */}
{/* HTML Structure                     */}
{/* ================================== */}
<div class="pinned-header">
  <h2>Pinned</h2>
  <a href="#" class="customize-link">Customize your pins</a>
</div>

<div class="repos-grid">
  <!-- Repository 1 -->
  <div class="repo-card">
    <button class="repo-menu" aria-label="Menu">⋮</button>
    <div class="repo-header">
      <span class="repo-icon">
        <svg
          aria-hidden="true"
          height="16"
          viewBox="0 0 16 16"
          version="1.1"
          width="16"
          data-view-component="true"
        >
