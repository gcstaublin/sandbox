      <span>TypeScript</span>
    </div>
  </div>
</div>
{/* ================================== */}
{/* Style                              */}
{/* ================================== */}
<style is:global>
  /* Header section */
  .pinned-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .pinned-header h2 {
    font-size: 16px;
    font-weight: 600;
  }

  .customize-link {
    font-size: 14px;
    color: #0366d6;
    text-decoration: none;
  }

  .customize-link:hover {
    text-decoration: underline;
  }

  /* Grid layout for repositories */
  .repos-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  /* Repository card */
  .repo-card {
    background-color: #fff;
    border: 1px solid #e1e4e8;
    border-radius: 6px;
    padding: 16px;
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  /* Repository header with icon, name and visibility */
  .repo-header {
    display: flex;
    align-items: center;
    margin-bottom: 8px;
  }

  .repo-icon {
    color: #586069;
    margin-right: 8px;
  }

  .repo-name {
    font-weight: 600;
    font-size: 14px;
    color: #0366d6;
    text-decoration: none;
    margin-right: 8px;
  }

  .repo-name:hover {
    text-decoration: underline;
  }

  .repo-visibility {
    font-size: 12px;
    color: #586069;
    border: 1px solid #e1e4e8;
    border-radius: 2em;
    padding: 0 7px;
    font-weight: 500;
  }

  /* Repository menu button */
  .repo-menu {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: #586069;
    cursor: pointer;
    font-size: 16px;
  }

  /* Repository description */
  .repo-description {
    font-size: 12px;
    color: #586069;
    margin-bottom: 16px;
    flex-grow: 1;
  }

  /* Language tag */
  .language-tag {
    display: flex;
    align-items: center;
    font-size: 12px;
    color: #586069;
  }

  .language-color {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-right: 5px;
  }

  .color-astro {
    background-color: #ff5a03;
  }

  .color-javascript {
    background-color: #f1e05a;
  }

  .color-typescript {
    background-color: #2b7489;
  }

  /* Responsive styles */
  @media (max-width: 768px) {
    .repos-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    body {
      padding: 12px;
    }

    .repo-card {
      padding: 12px;
    }

    .pinned-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>
